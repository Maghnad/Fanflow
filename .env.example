# ──────────────────────────────────────────────
# FanFlow AI — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ──────────────────────────────────────────────

# LLM Provider Configuration
# Supported: "openai", "google", "anthropic", "groq", "together", "ollama"
# The app uses an OpenAI-compatible REST API by default.
# Change LLM_BASE_URL to point at any compatible endpoint.
LLM_PROVIDER=groq
LLM_MODEL=llama3-8b-8192
LLM_API_KEY=your_groq_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1

# CORS — comma-separated list of allowed origins (no wildcards)
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Rate Limiting — requests per minute per IP
RATE_LIMIT=60

# App
APP_ENV=development
LOG_LEVEL=info
